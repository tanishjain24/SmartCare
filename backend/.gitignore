# Backend .gitignore

# Environment variables
.env
.env.local
.env.*.local
*.env

# Dependencies
node_modules/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Uploads (user-uploaded files)
uploads/*
!uploads/.gitkeep

# Database
*.sqlite
*.db

# OS files
.DS_Store
.DS_Store?
._*
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
*.swp
*.swo
*.swn

# Testing
coverage/
.nyc_output/

# Build outputs
dist/
build/

# Misc
*.pem
*.key
.vercel
.render

# Keep example files
!.env.example

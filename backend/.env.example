# Backend Environment Variables
# Copy this file to .env for local development
# Set these in Render dashboard for production

# Database
MONGO_URI=mongodb://localhost:27017/test

# JWT & Security
JWT_SECRET=your-jwt-secret-key-change-this-to-random-string
MASTER_KEY=your-master-key-change-this-to-random-string

# Email Configuration (for OTP)
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-gmail-app-password

# Cloudinary Configuration (for encrypted file storage)
# Store encrypted .enc files as resource_type=raw.
CLOUDINARY_CLOUD_NAME=smartcare
CLOUDINARY_API_KEY=179335273548269
CLOUDINARY_API_SECRET=XMWUHn9BuK1O4Xxvu8P8_7jvq6w
# Optional: Cloudinary folder name
CLOUDINARY_FOLDER=smartcare

